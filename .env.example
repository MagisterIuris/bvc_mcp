# BVC MCP Server — Environment Variables
# Copy this file to .env and adjust if needed.
# Currently no authentication is required to access the BVC data endpoint.

# Cache TTL in seconds (default: 300 = 5 minutes)
# CACHE_TTL_SECONDS=300

# HTTP request timeout in seconds (default: 15)
# REQUEST_TIMEOUT_SECONDS=15

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# Database (override for production)
BVC_DB_PATH=/data/bvc_history.db

# Multi-user isolation (optionnel, pour usage local mono-user)
# BVC_USER_ID=hamza

# MCPize will inject user API keys automatically via tool parameters
# No additional configuration needed for multi-user isolation
